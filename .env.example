# ─── Database ────────────────────────────────────────────────────────────────
# Neon Postgres — https://neon.tech (free tier is plenty for early stage).
# DATABASE_URL is the POOLED url (...-pooler...) used by the app at runtime.
# DIRECT_URL is the non-pooled url used by `prisma db push` / `prisma migrate`.

DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Public base URL ──────────────────────────────────────────────────────────
# Used in reminder emails so links resolve correctly on every environment.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com — 3,000 emails/month free, 100/day, no KYC.
# Without these, the email wrapper logs to the console (simulated mode).
RESEND_API_KEY=""
RESEND_FROM="ShakeOnIt <onboarding@resend.dev>"

# ─── Cron auth ────────────────────────────────────────────────────────────────
# Random string. Vercel Cron passes this as `Authorization: Bearer $CRON_SECRET`.
# For manual testing locally: hit /api/cron/* with ?key=$CRON_SECRET
CRON_SECRET=""

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Set to "false" once you wire a real SMS provider for OTP. Defaults to demo mode
# where the code "000000" always works.
DEMO_OTP="true"

# ─── Payments (optional — simulated mode is the default) ──────────────────────
# Pick ONE provider when you're ready. Cashfree recommended for India (faster KYC
# than Razorpay). Setu also works well for BaaS-style integration.
PAYMENT_PROVIDER=""            # "cashfree" | "" (simulated)
PAYMENT_ENV=""                 # "test" | "live"
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
