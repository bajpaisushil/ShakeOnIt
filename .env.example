# ─── Database ────────────────────────────────────────────────────────────────
# Neon Postgres (https://neon.tech) — sign up free, create a project, copy URLs.
#
# Both are needed:
#   DATABASE_URL — Neon's POOLED connection (URL ends in "-pooler.<region>.aws.neon.tech")
#                  Used by the app at runtime. Required for serverless on Vercel.
#   DIRECT_URL   — Neon's DIRECT connection (URL ends in "<region>.aws.neon.tech")
#                  Used only by `prisma db push` / `prisma migrate`.

DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
