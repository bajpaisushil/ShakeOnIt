generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // Neon's pooled URL (...-pooler...) — used at runtime
  directUrl = env("DIRECT_URL")         // Neon's direct URL — used by `prisma db push` / migrate
}

// ─── Users ───────────────────────────────────────────────────────────────
model User {
  id        String     @id @default(cuid())
  phone     String     @unique
  name      String?
  email     String?
  lang      String     @default("en")
  createdAt DateTime   @default(now())

  // Suspension state — reserved for manual admin action (e.g. abuse).
  // Not auto-triggered in the current flow; the promise-keeping score handles accountability.
  suspendedAt        DateTime?
  suspensionReason   String?
  outstandingPaise   Int       @default(0)

  // Promise-keeping score. Starts at 100 (perfect). Drops when contracts go
  // overdue. Shown on dashboard + (anonymized) on the public wall for severe drops.
  promiseScore       Int       @default(100)

  waitlist  Waitlist[]
  sessions  Session[]
  mandates  Mandate[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

// One-time codes for phone OTP login. Codes auto-expire.
model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String   // 6-digit code
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([expiresAt])
}

// ─── Contracts ───────────────────────────────────────────────────────────
// Captures interest in the Pro tier + the draft contract + signing + payment state.
model Waitlist {
  id              String   @id @default(cuid())
  userId          String?

  templateType    String   // "loan" | "expense" | "service"
  contractData    String   // JSON blob of template-specific fields
  creatorName     String
  creatorEmail    String
  creatorPhone    String
  recipientName   String?
  recipientPhone  String?
  draftText       String   // human-readable contract render

  // Demo Aadhaar eSign state
  signedAt           DateTime?
  signatureHash      String?
  signerNameOnAadhaar String?
  isDemoSigned       Boolean   @default(false)

  // Razorpay state
  paidPaise          Int?
  razorpayOrderId    String?
  razorpayPaymentId  String?
  paidAt             DateTime?

  // Auto-debit configuration — kept for future provider integration; not user-facing in v1.
  autoDebitEnabled   Boolean   @default(false)
  autoDebitAmountPaise Int?

  // Lender's UPI VPA — appears as a "Pay via UPI" tap-to-pay link in reminders and on /my.
  upiVpa             String?

  // Settlement state (the lightweight alternative to auto-debit)
  reminderSentAt     DateTime?
  markedPaidAt       DateTime?    // borrower clicked "I've paid" — informational
  markedReceivedAt   DateTime?    // lender confirmed "received" — source of truth
  overdueWallPostedAt DateTime?   // posted as broken-promise on public wall

  // Random token for unauthenticated mark-as-paid / mark-as-received links in emails.
  confirmToken       String?   @unique

  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  mandate Mandate?

  @@index([createdAt])
  @@index([creatorEmail])
  @@index([userId])
}

// Auto-debit mandate. In production, this is a Razorpay Subscription / UPI Token.
// In demo, this is a simulated row that the user can manually trigger to test
// the success/failure→suspension flow.
model Mandate {
  id                     String   @id @default(cuid())
  userId                 String
  waitlistId             String?  @unique

  status                 String   // "pending" | "active" | "succeeded" | "failed" | "cancelled"
  amountPaise            Int
  scheduledFor           DateTime // when the debit fires
  attemptsCount          Int      @default(0)
  lastAttemptAt          DateTime?
  succeededAt            DateTime?
  failedAt               DateTime?
  failureReason          String?

  // Razorpay identifiers — null in simulated mode
  razorpayTokenId        String?
  razorpaySubscriptionId String?
  razorpayPaymentId      String?

  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  waitlist Waitlist? @relation(fields: [waitlistId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([scheduledFor, status])
}

// Anonymized public-wall entries.
model PublicPromise {
  id           String    @id @default(cuid())
  kind         String    // "pinky" | "pro-draft" | "pro-signed"
  templateType String?
  blurb        String
  amount       Int?      // paise
  createdAt    DateTime  @default(now())
  agreedAt     DateTime?

  @@index([createdAt])
}
